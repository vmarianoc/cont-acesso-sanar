PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/accessplatform
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
NODE_ENV=development

# Credenciais da service account do Firebase (JSON completo, em uma linha).
# Sem esta variável, o worker de notificações roda em modo degradado (loga
# em vez de enviar push de verdade) — útil em dev/test sem projeto Firebase.
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
